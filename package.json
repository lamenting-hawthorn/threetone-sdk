{
  "name": "@threetone/sdk",
  "version": "0.2.1",
  "description": "Official TypeScript SDK for the Threetone Labs voice AI platform.",
  "license": "MIT",
  "author": "Threetone Labs",
  "homepage": "https://threetone.in",
  "repository": {
    "type": "git",
    "url": "https://github.com/lamenting-hawthorn/threetone-sdk.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "threetone",
    "voice-ai",
    "voice-agent",
    "indic-languages",
    "outbound-calling",
    "conversational-ai",
    "sdk",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/lamenting-hawthorn/threetone-sdk/issues"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "pnpm generate && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.examples.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm generate && pnpm lint && pnpm typecheck && pnpm test:types && pnpm build && pnpm test"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.10.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "^1.9.4",
    "@hey-api/openapi-ts": "^0.64.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "msw": "^2.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
